# Frontend environment variables (optional in development).
#
# In development you can leave this empty — Vite proxies /api to the backend
# on http://localhost:5000 (see vite.config.js).
#
# In production, set this to your deployed backend URL, e.g.
# VITE_API_BASE=https://ai-code-review-api.onrender.com
VITE_API_BASE=
