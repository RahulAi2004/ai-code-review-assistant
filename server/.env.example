# --- AI Code Review Assistant: backend environment variables ---

# Google Gemini API key. Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use for reviews
GEMINI_MODEL=gemini-2.5-flash-lite

# Port the Express server listens on
PORT=5000

# (Optional) GitHub personal access token. Raises the GitHub API rate limit
# from 60 to 5000 requests/hour. Only needs "public_repo" scope.
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=

# (Optional) MongoDB connection string for user accounts and saved review history.
# Leave blank for development — the server starts an in-memory MongoDB automatically
# (data is ephemeral). For real persistence / deployment, use MongoDB Atlas:
# https://www.mongodb.com/atlas  e.g. mongodb+srv://user:pass@cluster.mongodb.net/aicodereview
MONGODB_URI=

# Secret used to sign JWT auth tokens. Change this to a long random string.
JWT_SECRET=change-me-to-a-long-random-secret
